# OpenAI 호환 엔드포인트 설정 (gpt-oss / Ollama / vLLM 등)
# 인증은 HTTP 헤더로 처리 (src/llm.py DEFAULT_HEADERS 참조)
#
# Ollama 예시:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=gpt-oss:20b
# vLLM 예시:
#   OPENAI_BASE_URL=http://localhost:8000/v1
#   OPENAI_MODEL=openai/gpt-oss-20b

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=gpt-oss:20b

# 선택: 노드별 모델 분리 (미설정 시 OPENAI_MODEL 사용)
# EXTRACTOR_MODEL=gpt-oss:20b
# JUDGE_MODEL=gpt-oss:20b
# WRITER_MODEL=gpt-oss:20b

# 호출 제한 (Rate Limiting)
# 200건 이상 데이터 처리 시 Send 병렬 디스패치 API 폭주 방지
LLM_MAX_RPM=12            # 분당 최대 호출 수 (10~15 권장)
LLM_MAX_CONCURRENT=5      # 동시 호출 상한 (스레드 자원 보호)

# 선택: 추가 인증 헤더 (JSON 문자열, DEFAULT_HEADERS 에 병합)
# OPENAI_EXTRA_HEADERS={"Authorization": "Bearer xxx", "X-Project-Id": "my-project"}
